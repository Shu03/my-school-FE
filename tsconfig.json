{
    "files": [],
    "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@app/*": ["./src/app/*"],
            "@features/*": ["./src/features/*"],
            "@components/*": ["./src/components/*"],
            "@layouts": ["./src/layouts"],
